{
  "expo": {
    "name": "VITA",
    "slug": "vita",
    "version": "1.0.0",
    "scheme": "vita",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.vita.health"
    },
    "android": {
      "package": "com.vita.health",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#FAFAF8",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.health.READ_HEART_RATE",
        "android.permission.health.READ_SLEEP",
        "android.permission.health.READ_STEPS",
        "android.permission.health.READ_OXYGEN_SATURATION",
        "android.permission.health.READ_HEART_RATE_VARIABILITY",
        "android.permission.health.READ_ACTIVE_CALORIES_BURNED"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-image-picker",
        {
          "cameraPermission": "VITA uses the camera to photograph medical reports you choose to add.",
          "photosPermission": "VITA accesses photos you select to add medical reports."
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FAFAF8",
          "image": "./assets/splash-icon.png",
          "imageWidth": 160
        }
      ],
      "expo-background-task",
      [
        "@kingstinct/react-native-healthkit",
        {
          "NSHealthShareUsageDescription": "VITA reads heart rate, sleep, steps, blood oxygen, HRV, and active energy to learn your personal baseline and show meaningful changes. Nothing is shared without your action.",
          "NSHealthUpdateUsageDescription": false
        }
      ],
      "./plugins/withHealthConnect",
      "expo-localization",
      [
        "expo-audio",
        {
          "microphonePermission": "VITA uses the microphone so you can ask about your health by voice."
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 26
          }
        }
      ],
      "@react-native-google-signin/google-signin"
    ]
  }
}
